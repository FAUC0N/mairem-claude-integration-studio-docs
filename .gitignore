# =============================================================================
# .gitignore — mAIrem Claude Integration Studio
# site/ is a build artifact generated by mkdocs build; never commit it.
# =============================================================================

# MkDocs build output
site/

# Python bytecode and virtual environments
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.user

# .NET build outputs (for when C# source is added in later phases)
bin/
obj/
*.user
*.suo
*.vs/
